    "# 1. Get predictions on the test dataset using the Trainer\n",
    "predictions_output = trainer.predict(tokenized_test)\n",
    "\n",
    "# 2. Convert raw logits into predicted class labels (0, 1, 2, 3)\n",
    "y_pred_bert = np.argmax(predictions_output.predictions, axis=-1)\n",
    "\n",
    "# 3. Extract the true labels\n",
    "y_true_bert = predictions_output.label_ids \n",
    "\n",
    "# 4. Calculate and print the final accuracy\n",
    "final_accuracy = accuracy_score(y_true_bert, y_pred_bert)\n",
    "print(f'Final BERT Test Accuracy: {final_accuracy * 100:.2f}%\\n')\n",
    "\n",
    "# 5. Generate the confusion matrix\n",
    "conf_matrix_bert = confusion_matrix(y_true_bert, y_pred_bert)\n",
    "\n",
    "# AG News Class Labels mapping (Remember we shifted them to 0-3 earlier)\n",
    "class_labels = ['World', 'Sports', 'Business', 'Sci/Tech']\n",
    "\n",
    "# 6. Plot the heatmap\n",
    "plt.figure(figsize=(10, 7))\n",
    "sns.heatmap(conf_matrix_bert, annot=True, fmt='d', cmap='Blues', \n",
    "            xticklabels=class_labels, yticklabels=class_labels)\n",
    "plt.title('BERT Confusion Matrix')\n",
    "plt.xlabel('Predicted Label')\n",
    "plt.ylabel('True Label')\n",
    "plt.show()"
   ]
  }
